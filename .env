# .env
# OpenAI API Key - Dapatkan di https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Port server
PORT=3000

# AI Model
AI_MODEL=gpt-3.5-turbo

# AI System Prompt (kepribadian bot)
AI_SYSTEM_PROMPT=Kamu adalah asisten virtual yang ramah dan helpful. Jawab dalam bahasa yang sama dengan pengirim pesan. Jawab dengan singkat, padat, dan jelas. Jika ditanya siapa kamu, jawab bahwa kamu adalah asisten AI dari WhatsApp Auto-Reply Bot.

# Pengaturan Auto-Reply
AUTO_REPLY_ENABLED=true
REPLY_TO_GROUPS=false
MAX_TOKENS=500

# Nomor yang diabaikan (pisahkan dengan koma)
IGNORED_NUMBERS=

# Delay reply (ms) - agar terlihat natural
REPLY_DELAY=2000
